<script>
  function syncStatsHalf() {
    const inner = document.querySelector<HTMLElement>('.stats .stats-inner');
    if (!inner) return;
    const half = Math.ceil(inner.getBoundingClientRect().height / 2);
    document.documentElement.style.setProperty('--stats-half', `${half}px`);
  }

  let statsHalfObserver: ResizeObserver | null = null;

  function watchStatsHalf() {
    const inner = document.querySelector<HTMLElement>('.stats .stats-inner');
    if (!inner) return;
    syncStatsHalf();
    statsHalfObserver?.disconnect();
    statsHalfObserver = new ResizeObserver(syncStatsHalf);
    statsHalfObserver.observe(inner);
  }

  function formatStatValue(value: number, el: HTMLElement) {
    const decimals = parseInt(el.dataset.decimals || '0', 10);
    const suffix = el.dataset.suffix || '';
    const useComma = el.dataset.format === 'comma';
    const fixed = value.toFixed(decimals);
    const [whole, frac] = fixed.split('.');
    const formattedWhole = useComma
      ? Number(whole).toLocaleString('en-US')
      : whole;
    return frac && decimals > 0 ? `${formattedWhole}.${frac}${suffix}` : `${formattedWhole}${suffix}`;
  }

  function animateStatCount(el: HTMLElement, duration = 1400) {
    const target = parseFloat(el.dataset.count || '0');
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced || Number.isNaN(target)) return;

    const start = performance.now();
    const tick = (now: number) => {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = target * eased;
      el.textContent = formatStatValue(current, el);
      if (progress < 1) requestAnimationFrame(tick);
      else el.textContent = formatStatValue(target, el);
    };
    requestAnimationFrame(tick);
  }

  function initStatsRibbon() {
    const ribbon = document.getElementById('stats-ribbon');
    if (!ribbon) return;

    syncStatsHalf();
    watchStatsHalf();

    if (ribbon.dataset.ready === '1') return;
    ribbon.dataset.ready = '1';

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting || ribbon.classList.contains('in-view')) return;
          ribbon.classList.add('in-view');
          ribbon.querySelectorAll<HTMLElement>('.stat-val[data-count]').forEach((el, i) => {
            window.setTimeout(() => animateStatCount(el), 180 + i * 90);
          });
          observer.disconnect();
        });
      },
      { threshold: 0.35, rootMargin: '0px 0px -8% 0px' }
    );

    observer.observe(ribbon);
  }

  initStatsRibbon();
  document.addEventListener('astro:page-load', initStatsRibbon);
  window.addEventListener('resize', syncStatsHalf, { passive: true });
</script>

