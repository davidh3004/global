        <div class="buy-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 21 8 3"/><path d="M20 21 16 3"/><line x1="12" y1="5" x2="12" y2="8"/><line x1="12" y1="11" x2="12" y2="14"/><line x1="12" y1="17" x2="12" y2="20"/></svg>
        </div>
        <h3 data-i18n="whatWeBuy.asphalt.title">{t('whatWeBuy.asphalt.title', locale)}</h3>
        <p data-i18n="whatWeBuy.asphalt.desc">{t('whatWeBuy.asphalt.desc', locale)}</p>
      </div>
      <div class="buy-item fade fade-d3">
        <div class="buy-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="1"/><line x1="3" y1="9.3" x2="21" y2="9.3"/><line x1="3" y1="14.6" x2="21" y2="14.6"/><line x1="9" y1="4" x2="9" y2="9.3"/><line x1="15" y1="9.3" x2="15" y2="14.6"/><line x1="9" y1="14.6" x2="9" y2="20"/></svg>
        </div>
        <h3 data-i18n="whatWeBuy.brick.title">{t('whatWeBuy.brick.title', locale)}</h3>
        <p data-i18n="whatWeBuy.brick.desc">{t('whatWeBuy.brick.desc', locale)}</p>
      </div>
      <div class="buy-item fade fade-d4">
        <div class="buy-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="m4 20 5-10 3 5 2-3 6 8"/><circle cx="8" cy="6" r="1.4"/></svg>
        </div>
        <h3 data-i18n="whatWeBuy.rock.title">{t('whatWeBuy.rock.title', locale)}</h3>
        <p data-i18n="whatWeBuy.rock.desc">{t('whatWeBuy.rock.desc', locale)}</p>
      </div>
    </div>
  </div>
</section>

<style>
  /* ---- Hero heritage accents ---- */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: 'Oswald', 'Arial Narrow', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #8FE0A6;
    margin-bottom: 20px;
  }

  .hero-eyebrow-line { width: 40px; height: 2px; background: #8FE0A6; }

  /* Hero phone CTA — old-school "call now" */
  .hero-call {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Oswald', 'Arial Narrow', sans-serif;
    letter-spacing: 1px;
    font-weight: 600;
  }
  .hero-call svg { stroke: #8FE0A6; }

  /* Mobile-only "Request a Quote" (quote card is hidden < 900px) */
  .hero-btn-quote-m { display: none; }

  /* Heritage trust strip */
  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 22px;
  }
  .hero-chip {
    font-family: 'Oswald', 'Arial Narrow', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #BCE6C8;
    border: 1px solid rgba(143, 224, 166, 0.4);
    background: rgba(255, 255, 255, 0.05);
    border-radius: 3px;
    padding: 6px 12px;
  }
  .hero-chip b { color: #fff; font-weight: 700; }

  @media (max-width: 900px) {
    .hero-btn-quote-m { display: inline-flex; }
  }

  .what-we-buy {
    padding: 84px 0;
    background:
      linear-gradient(rgba(247,244,236,0.92), rgba(247,244,236,0.92)),
      repeating-linear-gradient(45deg, #e7e1d2 0 1px, transparent 1px 16px);
    border-top: 3px solid var(--green-dark);
    border-bottom: 3px solid var(--green-dark);
  }

  .wwb-head { text-align: center; max-width: 760px; margin: 0 auto 52px; }

  /* Centered heritage "stamp" eyebrow with flanking rules */
  .sec-stamp {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    font-family: 'Oswald', 'Arial Narrow', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--green-dark);
    margin-bottom: 14px;
  }

  .sec-stamp-rule { width: 42px; height: 2px; background: var(--green); }

  .what-we-buy .sec-title {
    font-family: 'Roboto Slab', Georgia, serif;
    text-align: center;
  }

  .sec-lead {
    text-align: center;
    max-width: 640px;
    margin: 16px auto 0;
    font-size: 17px;
    color: var(--gray-600);
    line-height: 1.7;
  }

  .buy-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 26px;
    margin-top: 4px;
  }

  .buy-item {
    text-align: center;
    padding: 38px 26px 32px;
    border-radius: 6px;
    background: #fff;
    border: 2px solid var(--green-dark);
    box-shadow: 6px 6px 0 rgba(31, 107, 58, 0.14);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .buy-item:hover {
    transform: translateY(-5px);
    box-shadow: 9px 9px 0 rgba(31, 107, 58, 0.2);
  }

  .buy-icon {
    width: 72px;
    height: 72px;
    margin: 0 auto 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--green-dark);
    background: var(--green-pale);
    border: 2px solid var(--green-dark);
    border-radius: 50%;
  }

  .buy-icon svg { width: 36px; height: 36px; }

  .buy-item h3 {
    font-family: 'Roboto Slab', Georgia, serif;
    font-size: 21px;
    font-weight: 700;
    color: var(--green-dark);
    margin-bottom: 12px;
  }

  .buy-item p {
    font-size: 15px;
    color: var(--gray-600);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .what-we-buy { padding: 56px 0; }
    .wwb-head { margin-bottom: 36px; }
    .buy-grid { grid-template-columns: 1fr; gap: 18px; }
    .buy-item { padding: 30px 22px; }
  }
</style>

<!-- <LearningSection client:load lang={locale} /> -->

<PhotoGallery client:load />

<ContactSection client:load lang={locale} />

<div class="cta-band"><div class="cta-inner">
  <div class="cta-text"><h2 data-i18n="cta.title" data-html="true" set:html={t('cta.title', locale)}></h2><p data-i18n="cta.text">{t('cta.text', locale)}</p></div>
  <div class="cta-actions"><a href="#products" data-scroll-to="products" class="btn-white"><span data-i18n="cta.btnMaterials">{t('cta.btnMaterials', locale)}</span></a><a href="#hero" data-scroll-to="hero" class="btn-outline-white"><span data-i18n="cta.btnQuote">{t('cta.btnQuote', locale)}</span></a></div>
</div></div>

<script>
  function setupQuoteForm(formId: string, btnId: string, msgId: string) {
    const form = document.getElementById(formId) as HTMLFormElement | null;
    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById(btnId) as HTMLButtonElement;
      const msg = document.getElementById(msgId) as HTMLDivElement;
      const fd = new FormData(form);
      // Language is controlled by the client-side selector (i18next), not the URL.
      // Read the active language so success/error messages match what the user sees.
      const activeLang =
        (typeof localStorage !== 'undefined' && localStorage.getItem('language')) ||
        document.documentElement.lang ||
        'en';
      const isEnglish = activeLang !== 'es';

      btn.disabled = true;
      btn.textContent = isEnglish ? 'Sending...' : 'Enviando...';
      msg.style.display = 'none';

      try {
        const response = await fetch('/api/quote', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            name: fd.get('name') as string,
            material: fd.get('material') as string,
            quantity: fd.get('quantity') as string,
            contact: fd.get('contact') as string,
            language: isEnglish ? 'en' : 'es',
          }),
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.error || 'Failed to send quote request');
        }

        msg.style.display = 'block';
        msg.style.background = '#D1FAE5';
        msg.style.color = '#065F46';
        msg.textContent = isEnglish
          ? 'Request sent! We will contact you shortly.'
          : 'Solicitud enviada. Te contactaremos pronto.';
        form.reset();

        // Hide success message after 5 seconds
        setTimeout(() => {
          msg.style.display = 'none';
        }, 5000);

      } catch (err: any) {
        console.error('Quote form error:', err);
        msg.style.display = 'block';
        msg.style.background = '#FEE2E2';
        msg.style.color = '#991B1B';
        msg.textContent = isEnglish
          ? 'Error sending request. Please try again.'
          : 'Error al enviar. Intenta de nuevo.';
      } finally {
        btn.disabled = false;
        btn.textContent = (isEnglish ? 'Send Request' : 'Enviar Solicitud') + ' →';
      }
    });
  }

  setupQuoteForm('mainQuoteForm', 'mainQuoteBtn', 'mainQuoteMsg');
</script>

</PublicLayout>
