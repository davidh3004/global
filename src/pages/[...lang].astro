---
import PublicLayout from '../layouts/PublicLayout.astro';
import ProductsSection from '../components/home/ProductsSection';
import PhotoGallery from '../components/home/PhotoGallery';
import ContactSection from '../components/contact/ContactSection';
import { t } from '../utils/i18n';

export function getStaticPaths() {
  return [
    { params: { lang: undefined } }, // Root "/" → English (default)
    { params: { lang: 'en' } },      // "/en" → English (alias, keeps old links working)
    { params: { lang: 'es' } }       // "/es" → Spanish
  ];
}

const { lang } = Astro.params;
const locale = lang === 'es' ? 'es' : 'en';
const isEnglish = locale === 'en';

// Existing local imagery reused for the "What We Do" service cards
const buyPhotos = [
  '/uploads/gallery/1781130952072-wklb9s.jpeg',
  '/uploads/gallery/1781130952844-agoqdp.jpeg',
  '/uploads/gallery/1781130953245-xpo7ie.jpeg',
  '/uploads/gallery/1781130953971-aaiwlb.jpeg',
];
---

<PublicLayout
  title={isEnglish ? "Global Recycling of Tampa Bay — The World Is Yours" : "Global Recycling of Tampa Bay — El Mundo Es Tuyo"}
  description={isEnglish ? "Tampa Bay's trusted recycled concrete, asphalt, and aggregate supplier since 1990." : "Proveedor confiable de concreto reciclado, asfalto y agregados de Tampa Bay desde 1990."}
  lang={locale}
>

<!-- ============ HERO ============ -->
<section class="hero" id="hero">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-copy">
      <div class="hero-eyebrow"><span class="hero-eyebrow-line"></span><span data-i18n="hero.label">{t('hero.label', locale)}</span></div>
      <h1><span data-i18n="hero.title">{t('hero.title', locale)}</span> <span class="hl" data-i18n="hero.titleHighlight">{t('hero.titleHighlight', locale)}</span> <span data-i18n="hero.titleEnd">{t('hero.titleEnd', locale)}</span></h1>
      <p class="hero-sub" data-i18n="hero.subtitle">{t('hero.subtitle', locale)}</p>
      <div class="hero-btns">
        <a href="#products" data-scroll-to="products" class="btn-hero"><span data-i18n="hero.btnMaterials">{t('hero.btnMaterials', locale)}</span> →</a>
        <a href="#contact" data-scroll-to="contact" class="btn-hero-ghost hero-btn-quote-m"><span data-i18n="hero.btnQuote">{t('hero.btnQuote', locale)}</span></a>
        <a href="tel:8133736467" class="btn-hero-ghost hero-call" aria-label="Call (813) 373-6467">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          (813) 373-6467
        </a>
      </div>
      <div class="hero-trust">
        <span class="hero-chip"><b>EST.&nbsp;1990</b></span>
        <span class="hero-chip" data-i18n="hero.familyOwned">{t('hero.familyOwned', locale)}</span>
        <span class="hero-chip">★&nbsp;4.3 Google</span>
      </div>
    </div>
    <form class="quote-card" id="mainQuoteForm">
      <div class="qc-title" data-i18n="quote.title">{t('quote.title', locale)}</div>
      <div class="qc-sub" data-i18n="quote.subtitle">{t('quote.subtitle', locale)}</div>
      <div class="field"><label data-i18n="quote.name">{t('quote.name', locale)}</label><input type="text" name="name" required data-i18n-placeholder="quote.namePlaceholder" placeholder={t('quote.namePlaceholder', locale)}/></div>
      <div class="field-row">
        <div class="field"><label data-i18n="quote.material">{t('quote.material', locale)}</label><select name="material" id="quoteMatSelect"><option data-i18n="quote.materials.concrete">{t('quote.materials.concrete', locale)}</option><option data-i18n="quote.materials.asphalt">{t('quote.materials.asphalt', locale)}</option><option data-i18n="quote.materials.roadBase">{t('quote.materials.roadBase', locale)}</option><option data-i18n="quote.materials.paverBase">{t('quote.materials.paverBase', locale)}</option></select></div>
        <div class="field"><label data-i18n="quote.quantity">{t('quote.quantity', locale)}</label><input type="text" name="quantity" required data-i18n-placeholder="quote.quantityPlaceholder" placeholder={t('quote.quantityPlaceholder', locale)}/></div>
      </div>
      <div class="field"><label data-i18n="quote.contact">{t('quote.contact', locale)}</label><input type="text" name="contact" required data-i18n-placeholder="quote.contactPlaceholder" placeholder={t('quote.contactPlaceholder', locale)}/></div>
      <div id="mainQuoteMsg" style="display:none; padding: 8px; border-radius: 6px; font-size: 13px; margin-bottom: 8px;"></div>
      <button type="submit" class="btn-submit" id="mainQuoteBtn"><span data-i18n="quote.submit">{t('quote.submit', locale)}</span> →</button>
      <div class="qc-divider" data-i18n="quote.divider">{t('quote.divider', locale)}</div>
      <a href="tel:8133736467" class="qc-phone-link">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (813) 373-6467
      </a>
    </form>
  </div>
</section>

<!-- ============ STATS BAND (dark, overlaps hero) ============ -->
<div class="stats">
  <div class="stats-inner">
    <div class="stat">
      <div class="stat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="8" r="6"/><path d="M8.21 13.89 7 22l5-3 5 3-1.21-8.12"/></svg></div>
      <div class="stat-val">34+</div><div class="stat-lbl" data-i18n="stats.years">{t('stats.years', locale)}</div>
    </div>
    <div class="stat">
      <div class="stat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg></div>
      <div class="stat-val">14,400</div><div class="stat-lbl" data-i18n="stats.yards">{t('stats.yards', locale)}</div>
    </div>
    <div class="stat">
      <div class="stat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M7 19H4.815a1.83 1.83 0 0 1-1.57-.881 1.785 1.785 0 0 1-.004-1.784L7.196 9.5"/><path d="M11 19h8.203a1.83 1.83 0 0 0 1.556-.89 1.784 1.784 0 0 0 0-1.775l-1.226-2.12"/><path d="m14 16-3 3 3 3"/><path d="M8.293 13.596 4.875 9.5 1 10.5"/><path d="m9.344 5.811 1.093-1.892A1.83 1.83 0 0 1 11.985 3a1.784 1.784 0 0 1 1.546.888l3.943 6.843"/><path d="m13.378 9.633 4.295 1.151 1.038-3.875"/></svg></div>
      <div class="stat-val">100%</div><div class="stat-lbl" data-i18n="stats.recycled">{t('stats.recycled', locale)}</div>
    </div>
    <div class="stat">
      <div class="stat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
      <div class="stat-val">4.3★</div><div class="stat-lbl" data-i18n="stats.rating">{t('stats.rating', locale)}</div>
    </div>
  </div>
</div>

<!-- ============ WHAT WE DO (modern service cards) ============ -->
<section class="what-we-buy" id="what-we-do">
  <div class="container">
    <div class="wwb-head">
      <div class="sec-eyebrow fade" data-i18n="whatWeBuy.tag">{t('whatWeBuy.tag', locale)}</div>
      <h2 class="sec-headline fade fade-d1" data-i18n="whatWeBuy.title">{t('whatWeBuy.title', locale)}</h2>
      <p class="sec-lead fade fade-d2" data-i18n="whatWeBuy.lead">{t('whatWeBuy.lead', locale)}</p>
    </div>

    <div class="svc-grid">
      <a class="svc-card fade fade-d1" href="#products" data-scroll-to="products">
        <div class="svc-photo">
          <img src={buyPhotos[0]} alt="" loading="lazy"/>
          <span class="svc-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
          </span>
        </div>
        <div class="svc-body">
          <h3 data-i18n="whatWeBuy.concrete.title">{t('whatWeBuy.concrete.title', locale)}</h3>
          <p data-i18n="whatWeBuy.concrete.desc">{t('whatWeBuy.concrete.desc', locale)}</p>
          <span class="svc-more"><span data-i18n="learning.readMore">{t('learning.readMore', locale)}</span> →</span>
        </div>
      </a>

      <a class="svc-card fade fade-d2" href="#products" data-scroll-to="products">
        <div class="svc-photo">
          <img src={buyPhotos[1]} alt="" loading="lazy"/>
          <span class="svc-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 21 8 3"/><path d="M20 21 16 3"/><line x1="12" y1="5" x2="12" y2="8"/><line x1="12" y1="11" x2="12" y2="14"/><line x1="12" y1="17" x2="12" y2="20"/></svg>
          </span>
        </div>
        <div class="svc-body">
          <h3 data-i18n="whatWeBuy.asphalt.title">{t('whatWeBuy.asphalt.title', locale)}</h3>
          <p data-i18n="whatWeBuy.asphalt.desc">{t('whatWeBuy.asphalt.desc', locale)}</p>
          <span class="svc-more"><span data-i18n="learning.readMore">{t('learning.readMore', locale)}</span> →</span>
        </div>
      </a>

      <a class="svc-card fade fade-d3" href="#products" data-scroll-to="products">
        <div class="svc-photo">
          <img src={buyPhotos[2]} alt="" loading="lazy"/>
          <span class="svc-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="1"/><line x1="3" y1="9.3" x2="21" y2="9.3"/><line x1="3" y1="14.6" x2="21" y2="14.6"/><line x1="9" y1="4" x2="9" y2="9.3"/><line x1="15" y1="9.3" x2="15" y2="14.6"/><line x1="9" y1="14.6" x2="9" y2="20"/></svg>
          </span>
        </div>
        <div class="svc-body">
          <h3 data-i18n="whatWeBuy.brick.title">{t('whatWeBuy.brick.title', locale)}</h3>
          <p data-i18n="whatWeBuy.brick.desc">{t('whatWeBuy.brick.desc', locale)}</p>
          <span class="svc-more"><span data-i18n="learning.readMore">{t('learning.readMore', locale)}</span> →</span>
        </div>
      </a>

      <a class="svc-card fade fade-d4" href="#products" data-scroll-to="products">
        <div class="svc-photo">
          <img src={buyPhotos[3]} alt="" loading="lazy"/>
          <span class="svc-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="m4 20 5-10 3 5 2-3 6 8"/><circle cx="8" cy="6" r="1.4"/></svg>
          </span>
        </div>
        <div class="svc-body">
          <h3 data-i18n="whatWeBuy.rock.title">{t('whatWeBuy.rock.title', locale)}</h3>
          <p data-i18n="whatWeBuy.rock.desc">{t('whatWeBuy.rock.desc', locale)}</p>
          <span class="svc-more"><span data-i18n="learning.readMore">{t('learning.readMore', locale)}</span> →</span>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- ============ WHO WE ARE (dark panel + photo) ============ -->
<section class="about" id="about"><div class="container">
  <div class="about-grid">
    <div class="about-panel fade">
      <div class="sec-eyebrow on-dark"><span data-i18n="about.tag">{t('about.tag', locale)}</span></div>
      <h2 class="about-title"><span data-i18n="about.title">{t('about.title', locale)}</span> <span class="hl" data-i18n="about.titleHighlight">{t('about.titleHighlight', locale)}</span></h2>
      <div class="about-text">
        <p data-i18n="about.text1">{t('about.text1', locale)}</p>
        <p data-i18n="about.text2">{t('about.text2', locale)}</p>
      </div>
      <ul class="about-list">
        <li><div class="chk"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div><span data-i18n="about.list1">{t('about.list1', locale)}</span></li>
        <li><div class="chk"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div><span data-i18n="about.list2">{t('about.list2', locale)}</span></li>
        <li><div class="chk"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div><span data-i18n="about.list3">{t('about.list3', locale)}</span></li>
        <li><div class="chk"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div><span data-i18n="about.list4">{t('about.list4', locale)}</span></li>
      </ul>
      <a class="about-btn" href="/information"><span data-i18n="about.btnStory">{t('about.btnStory', locale)}</span> →</a>
    </div>
    <div class="about-photo fade fade-d1">
      <img src="/about-2.jpeg" alt="Operations at Global Recycling of Tampa Bay" loading="lazy"/>
      <div class="about-badge"><div class="about-badge-num">34+</div><div class="about-badge-lbl" data-i18n="about.badgeYears">{t('about.badgeYears', locale)}</div></div>
    </div>
  </div>
</div></section>

<!-- ============ MATERIALS WE SELL (live catalog) ============ -->
<ProductsSection client:load lang={locale} />

<!-- ============ OUR WORK IN ACTION (gallery) ============ -->
<PhotoGallery client:load />

<!-- ============ FIND US (map + info) ============ -->
<ContactSection client:load lang={locale} />

<!-- ============ CTA BAND ============ -->
<div class="cta-band"><div class="cta-inner">
  <div class="cta-text"><h2 data-i18n="cta.title" data-html="true" set:html={t('cta.title', locale)}></h2><p data-i18n="cta.text">{t('cta.text', locale)}</p></div>
  <div class="cta-actions"><a href="#products" data-scroll-to="products" class="btn-white"><span data-i18n="cta.btnMaterials">{t('cta.btnMaterials', locale)}</span></a><a href="tel:8133736467" class="btn-outline-white">{t('contact.phone', locale)} · (813) 373-6467</a></div>
</div></div>

<style>
  /* ====================================================================
     MODERN INDUSTRIAL HOMEPAGE (2026)
     Selectors are doubled / descendant-qualified to win the cascade over
     the single-class heritage rules in /original.css. Soft shadows,
     12px radius, Oswald display type — contractor / heavy-equipment feel.
     ==================================================================== */

  /* ---------- HERO ---------- */
  .hero.hero {
    min-height: 88vh;
    background: var(--section-dark);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    padding-top: 150px;
    padding-bottom: 80px;
  }
  .hero.hero::after { display: none; } /* kill heritage hatch texture */
  .hero .hero-bg {
    position: absolute;
    inset: 0;
    background: url('/about-1.jpeg') center/cover no-repeat;
    opacity: 1;
    filter: grayscale(12%) contrast(1.04);
    transform: scale(1.03);
  }
  .hero .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(100deg,
        rgba(7,26,16,0.94) 0%,
        rgba(7,26,16,0.80) 42%,
        rgba(7,26,16,0.48) 100%);
  }
  .hero .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 56px;
    align-items: center;
    width: 100%;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: 'Oswald', 'Arial Narrow', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--green-light);
    margin-bottom: 22px;
  }
  .hero-eyebrow-line { width: 42px; height: 2px; background: var(--green-light); }

  .hero.hero h1 {
    font-family: 'Oswald', 'Arial Narrow', sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(42px, 5.6vw, 70px);
    line-height: 1.02;
    letter-spacing: 0.5px;
    color: #fff;
    margin-bottom: 22px;
  }
  .hero.hero h1 span { color: #fff; }
  .hero.hero h1 span.hl { color: var(--green-light); }

  .hero .hero-sub {
    font-size: 18px;
    line-height: 1.7;
    color: rgba(255,255,255,0.84);
    max-width: 560px;
    margin-bottom: 32px;
  }

  .hero .hero-btns { display: flex; flex-wrap: wrap; gap: 14px; align-items: center; }
  .hero .btn-hero {
    padding: 15px 30px;
    font-family: 'Oswald', 'Arial Narrow', sans-serif;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 600;
    font-size: 15px;
    border-radius: 6px;
    box-shadow: 0 10px 26px rgba(47,158,84,0.34);
  }
  .hero .btn-hero:hover { background: var(--green-hover); transform: translateY(-2px); }
  .hero .btn-hero-ghost { border-radius: 6px; }

  /* Hero phone CTA — "call now" */
  .hero-call {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Oswald', 'Arial Narrow', sans-serif;
    letter-spacing: 1px;
    font-weight: 600;
    text-transform: uppercase;
  }
  .hero-call svg { stroke: var(--green-light); }

  /* Mobile-only "Request a Quote" (quote card is hidden < 900px) */
  .hero-btn-quote-m { display: none; }

  /* Trust strip */
  .hero-trust { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 26px; }
  .hero-chip {
    font-family: 'Oswald', 'Arial Narrow', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #BCE6C8;
    border: 1px solid rgba(76, 217, 123, 0.4);
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
    padding: 7px 13px;
  }
  .hero-chip b { color: #fff; font-weight: 700; }

  /* Quote card — modern soft card (overrides heritage hard-offset box) */
  .hero .quote-card {
    border: none;
    border-radius: 14px;
    box-shadow: 0 28px 64px rgba(0,0,0,0.40);
    padding: 30px;
    background: #fff;
  }
  .hero .qc-title {
    font-family: 'Oswald', 'Arial Narrow', sans-serif;
    font-size: 22px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.5px; color: var(--green-dark); margin-bottom: 2px;
  }
  .hero .qc-sub { font-size: 13px; color: var(--gray-600); margin-bottom: 18px; }
  .hero .btn-submit {
    border-radius: 7px; font-family: 'Oswald', 'Arial Narrow', sans-serif;
    text-transform: uppercase; letter-spacing: 1px; font-weight: 600; font-size: 15px;
    padding: 13px; display: flex; align-items: center; justify-content: center; gap: 6px;
  }
  .hero .btn-submit:hover { background: var(--green-hover); }
  .hero .qc-divider {
    text-align: center; font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px;
    color: var(--gray-400); margin: 16px 0 12px; position: relative;
  }
  .hero .qc-phone-link {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    font-family: 'Oswald', 'Arial Narrow', sans-serif; font-weight: 600; letter-spacing: 0.5px;
    color: var(--green); text-decoration: none;
  }

  /* ---------- STATS BAND (dark gradient, overlaps hero) ---------- */
  .stats.stats {
    background: linear-gradient(120deg, var(--forest-green) 0%, var(--section-dark) 100%);
    border: none;
    border-top: 3px solid var(--green-light);
    padding: 0;
    position: relative;
    z-index: 3;
  }
  .stats .stats-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    background: transparent;
    border: none;
    border-radius: 0;
    box-shadow: none;
    overflow: visible;
  }
  .stats .stat {
    padding: 38px 22px;
    text-align: center;
    border-right: 1px solid rgba(255,255,255,0.10);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .stats .stat:last-child { border-right: none; }
  .stats .stat-ico { width: 44px; height: 44px; color: var(--green-light); margin-bottom: 4px; }
  .stats .stat-ico svg { width: 100%; height: 100%; }
  .stats .stat-val {
    font-family: 'Oswald', 'Arial Narrow', sans-serif;
    font-size: 42px; font-weight: 700; color: #fff; line-height: 1; margin: 0;
  }
  .stats .stat-lbl {
    font-family: 'Oswald', 'Arial Narrow', sans-serif;
    font-size: 12px; font-weight: 500; letter-spacing: 1.5px;
    text-transform: uppercase; color: rgba(255,255,255,0.70);
  }

  /* ---------- SHARED SECTION HEADERS ---------- */
  .sec-eyebrow {
    display: inline-block;
