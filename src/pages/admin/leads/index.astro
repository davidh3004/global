---
/**
 * Admin Leads Page
 * Displays quote/contact form submissions from the Hero section
 * DRY: Follows the same pattern as Products, Reviews, and Learning admin pages
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Leads">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Leads</h1>
      <p class="text-gray-600 mt-1">Quote requests and contact form submissions</p>
    </div>
  </div>

  <div class="tabs tabs-boxed mb-6">
    <a class="tab tab-active" data-filter="all">All</a>
    <a class="tab" data-filter="new">New</a>
    <a class="tab" data-filter="read">Read</a>
    <a class="tab" data-filter="replied">Replied</a>
  </div>

  <div id="leads-container" class="bg-white rounded-lg shadow">
    <div class="p-8 text-center text-gray-500">
      Loading leads...
    </div>
  </div>
</AdminLayout>

<script>
  import { collection, query, orderBy, getDocs, deleteDoc, doc, updateDoc, where } from 'firebase/firestore';
  import { db } from '../../../firebase/client';
  import type { Lead } from '../../../firebase/types';

  let currentFilter = 'all';

  async function loadLeads() {
    const container = document.getElementById('leads-container');
    if (!container) return;

    try {
      let q;
      if (currentFilter !== 'all') {
        q = query(collection(db, 'leads'), where('status', '==', currentFilter), orderBy('createdAt', 'desc'));
      } else {
        q = query(collection(db, 'leads'), orderBy('createdAt', 'desc'));
      }

      const querySnapshot = await getDocs(q);
      const leads: Lead[] = [];

      querySnapshot.forEach((d) => {
        leads.push({ id: d.id, ...d.data() } as Lead);
      });

      if (leads.length === 0) {
        container.innerHTML = `
          <div class="p-12 text-center">
            <div class="text-6xl mb-4">📬</div>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">No leads yet</h3>
            <p class="text-gray-600">Quote requests from the site will appear here</p>
          </div>
        `;
        return;
      }

      container.innerHTML = `
        <div class="overflow-x-auto">
          <table class="table table-zebra w-full">
            <thead>
              <tr>
                <th>Date</th>
                <th>Name</th>
                <th>Material</th>
                <th>Quantity</th>
                <th>Contact</th>
                <th>Status</th>
                <th class="text-right">Actions</th>
              </tr>
            </thead>
            <tbody>
              ${leads.map(lead => {
                const date = lead.createdAt?.toDate ? lead.createdAt.toDate() : new Date();
                const statusBadge = lead.status === 'new' ? 'badge-info' :
                                    lead.status === 'read' ? 'badge-warning' : 'badge-success';
                const statusLabel = lead.status === 'new' ? 'New' :
                                    lead.status === 'read' ? 'Read' : 'Replied';
                return `
                  <tr>
                    <td class="text-sm">${date.toLocaleDateString('en-US')} ${date.toLocaleTimeString('en-US', {hour: '2-digit', minute: '2-digit'})}</td>
                    <td class="font-semibold">${lead.name}</td>
                    <td>${lead.material}</td>
                    <td>${lead.quantity}</td>
                    <td>
                      <a href="${lead.contact.includes('@') ? 'mailto:' + lead.contact : 'tel:' + lead.contact}" class="link link-primary">
                        ${lead.contact}
                      </a>
                    </td>
                    <td>
                      <select class="select select-bordered select-xs" data-status-select="${lead.id}" data-current="${lead.status}">
                        <option value="new" ${lead.status === 'new' ? 'selected' : ''}>New</option>
                        <option value="read" ${lead.status === 'read' ? 'selected' : ''}>Read</option>
                        <option value="replied" ${lead.status === 'replied' ? 'selected' : ''}>Replied</option>
                      </select>
                    </td>
                    <td class="text-right">
                      <button class="btn btn-sm btn-ghost text-error" data-delete-lead="${lead.id}" data-lead-name="${lead.name}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                      </button>
                    </td>
                  </tr>
                `;
              }).join('')}
            </tbody>
          </table>
        </div>
      `;

      // Attach status change listeners
      document.querySelectorAll('[data-status-select]').forEach(select => {
        select.addEventListener('change', async (e) => {
          const el = e.target as HTMLSelectElement;
          const id = el.dataset.statusSelect!;
          try {
            await updateDoc(doc(db, 'leads', id), { status: el.value });
          } catch (err: any) {
            alert('Error updating status: ' + err.message);
            await loadLeads();
          }
        });
      });

      // Attach delete listeners
      document.querySelectorAll('[data-delete-lead]').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = (btn as HTMLElement).dataset.deleteLead!;
          const name = (btn as HTMLElement).dataset.leadName!;
          if (!confirm(`Are you sure you want to delete the lead from "${name}"?`)) return;
          try {
            await deleteDoc(doc(db, 'leads', id));
            await loadLeads();
          } catch (err: any) {
            alert('Error deleting lead: ' + err.message);
          }
        });
      });

    } catch (error) {
      console.error('Error loading leads:', error);
      container.innerHTML = `
        <div class="p-8 text-center text-error">
          <p class="font-semibold mb-2">Error loading leads</p>
          <p class="text-sm">${error instanceof Error ? error.message : 'Unknown error'}</p>
        </div>
      `;
    }
  }

  // Tab filtering
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', (e) => {
      e.preventDefault();
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('tab-active'));
      (e.target as HTMLElement).classList.add('tab-active');
      currentFilter = (e.target as HTMLElement).dataset.filter || 'all';
      loadLeads();
    });
  });

  loadLeads();
</script>
