---
/**
 * Admin Orders Page
 * Displays all customer orders with status management
 * DRY: Follows the same pattern as Products, Reviews, Learning, and Leads admin pages
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Orders">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Orders</h1>
      <p class="text-gray-600 mt-1">Manage customer orders and payment status</p>
    </div>
  </div>

  <div class="tabs tabs-boxed mb-6">
    <a class="tab tab-active" data-filter="all">All</a>
    <a class="tab" data-filter="pending">Pending</a>
    <a class="tab" data-filter="processing">Processing</a>
    <a class="tab" data-filter="completed">Completed</a>
    <a class="tab" data-filter="cancelled">Cancelled</a>
  </div>

  <div id="orders-container" class="bg-white rounded-lg shadow">
    <div class="p-8 text-center text-gray-500">
      Loading orders...
    </div>
  </div>
</AdminLayout>

<script>
  import { collection, query, orderBy, getDocs, doc, updateDoc, where, Timestamp } from 'firebase/firestore';
  import { db } from '../../../firebase/client';
  import type { Order } from '../../../firebase/types';

  let currentFilter = 'all';

  async function loadOrders() {
    const container = document.getElementById('orders-container');
    if (!container) return;

    try {
      let q;
      if (currentFilter !== 'all') {
        q = query(collection(db, 'orders'), where('status', '==', currentFilter), orderBy('createdAt', 'desc'));
      } else {
        q = query(collection(db, 'orders'), orderBy('createdAt', 'desc'));
      }

      const querySnapshot = await getDocs(q);
      const orders: Order[] = [];

      querySnapshot.forEach((d) => {
        orders.push({ id: d.id, ...d.data() } as Order);
      });

      if (orders.length === 0) {
        container.innerHTML = `
          <div class="p-12 text-center">
            <div class="text-6xl mb-4">📋</div>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">No orders yet</h3>
            <p class="text-gray-600">Customer orders will appear here</p>
          </div>
        `;
        return;
      }

      container.innerHTML = `
        <div class="overflow-x-auto">
          <table class="table table-zebra w-full">
            <thead>
              <tr>
                <th>Order #</th>
                <th>Customer</th>
                <th>Items</th>
                <th>Total</th>
                <th>Payment</th>
                <th>Status</th>
                <th>Date</th>
                <th class="text-right">Actions</th>
              </tr>
            </thead>
            <tbody>
              ${orders.map(order => {
                const date = order.createdAt?.toDate ? order.createdAt.toDate() : new Date();
                const paymentBadge = order.paymentStatus === 'paid' ? 'badge-success' :
                                     order.paymentStatus === 'failed' ? 'badge-error' :
                                     order.paymentStatus === 'refunded' ? 'badge-warning' : 'badge-ghost';
                return `
                  <tr>
                    <td class="font-mono font-semibold">${order.orderNumber}</td>
                    <td>
                      <div class="font-semibold">${order.customerName}</div>
                      <div class="text-sm text-gray-500">${order.customerEmail}</div>
                    </td>
                    <td>${order.items?.length || 0} items</td>
                    <td class="font-semibold">$${order.total?.toFixed(2) || '0.00'}</td>
                    <td>
                      <span class="badge ${paymentBadge} badge-sm">
                        ${order.paymentStatus?.charAt(0).toUpperCase() + order.paymentStatus?.slice(1) || 'Pending'}
                      </span>
                    </td>
                    <td>
                      <select class="select select-bordered select-xs" data-order-status="${order.id}">
                        <option value="pending" ${order.status === 'pending' ? 'selected' : ''}>Pending</option>
                        <option value="processing" ${order.status === 'processing' ? 'selected' : ''}>Processing</option>
                        <option value="completed" ${order.status === 'completed' ? 'selected' : ''}>Completed</option>
                        <option value="cancelled" ${order.status === 'cancelled' ? 'selected' : ''}>Cancelled</option>
                      </select>
                    </td>
                    <td class="text-sm">${date.toLocaleDateString('en-US')}</td>
                    <td class="text-right">
                      <button class="btn btn-sm btn-ghost" data-view-order="${order.id}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                        </svg>
                      </button>
                    </td>
                  </tr>
                `;
              }).join('')}
            </tbody>
          </table>
        </div>
      `;

      // Attach status change listeners
      document.querySelectorAll('[data-order-status]').forEach(select => {
        select.addEventListener('change', async (e) => {
          const el = e.target as HTMLSelectElement;
          const id = el.dataset.orderStatus!;
          const updates: any = {
            status: el.value,
            updatedAt: Timestamp.now(),
          };
          if (el.value === 'completed') updates.completedAt = Timestamp.now();
          try {
            await updateDoc(doc(db, 'orders', id), updates);
          } catch (err: any) {
            alert('Error updating order: ' + err.message);
            await loadOrders();
          }
        });
      });

      // View order detail (shows alert with items for now)
      document.querySelectorAll('[data-view-order]').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = (btn as HTMLElement).dataset.viewOrder!;
          const order = orders.find(o => o.id === id);
          if (!order) return;
          const itemsList = order.items?.map(i =>
            `${i.productName} x${i.quantity} = $${i.subtotal.toFixed(2)}`
          ).join('\n') || 'No items';
          alert(
            `Order: ${order.orderNumber}\n` +
            `Customer: ${order.customerName} (${order.customerEmail})\n` +
            `Phone: ${order.customerPhone || 'N/A'}\n\n` +
            `Items:\n${itemsList}\n\n` +
            `Subtotal: $${order.subtotal?.toFixed(2)}\n` +
            `Tax: $${order.tax?.toFixed(2)}\n` +
            `Total: $${order.total?.toFixed(2)}\n\n` +
            `Notes: ${order.notes || 'None'}`
          );
        });
      });

    } catch (error) {
      console.error('Error loading orders:', error);
      container.innerHTML = `
        <div class="p-8 text-center text-error">
          <p class="font-semibold mb-2">Error loading orders</p>
          <p class="text-sm">${error instanceof Error ? error.message : 'Unknown error'}</p>
        </div>
      `;
    }
  }

  // Tab filtering
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', (e) => {
      e.preventDefault();
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('tab-active'));
      (e.target as HTMLElement).classList.add('tab-active');
      currentFilter = (e.target as HTMLElement).dataset.filter || 'all';
      loadOrders();
    });
  });

  loadOrders();
</script>
