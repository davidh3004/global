---
import AdminLayout from '../../../../layouts/AdminLayout.astro';

const { id } = Astro.params;
---

<AdminLayout title="Editar Producto">
  <div class="mb-6">
    <a href="/admin/products" class="text-sm text-gray-600 hover:text-gray-900 flex items-center gap-2 mb-4">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Volver a productos
    </a>
    <h1 class="text-3xl font-bold text-gray-900">Editar Producto</h1>
  </div>

  <div id="form-container" class="bg-white rounded-lg shadow p-6 max-w-3xl">
    <div class="text-center py-8">
      <span class="loading loading-spinner loading-lg"></span>
      <p class="text-gray-600 mt-4">Cargando producto...</p>
    </div>
  </div>
</AdminLayout>

<script>
  import { doc, getDoc, updateDoc, Timestamp } from 'firebase/firestore';
  import { db } from '../../../../firebase/client';

  const productId = window.location.pathname.split('/').pop() || '';

  async function loadProduct() {
    const container = document.getElementById('form-container');
    if (!container) return;

    if (!productId) {
      container.innerHTML = `
        <div class="text-center py-8">
          <p class="text-error font-semibold">ID de producto inválido</p>
          <a href="/admin/products" class="btn btn-primary mt-4">Volver a productos</a>
        </div>
      `;
      return;
    }

    try {
      const docRef = doc(db, 'products', productId);
      const docSnap = await getDoc(docRef);

      if (!docSnap.exists()) {
        container.innerHTML = `
          <div class="text-center py-8">
            <p class="text-error font-semibold">Producto no encontrado</p>
            <a href="/admin/products" class="btn btn-primary mt-4">Volver a productos</a>
          </div>
        `;
        return;
      }

      const product = docSnap.data();

      container.innerHTML = `
        <form id="product-form" class="space-y-6">
          <div class="form-control">
            <label class="label">
              <span class="label-text font-semibold">Nombre del Producto *</span>
            </label>
            <input type="text" name="name" required class="input input-bordered w-full" value="${product.name}" />
          </div>

          <div class="form-control">
            <label class="label">
              <span class="label-text font-semibold">Descripción *</span>
            </label>
            <textarea name="description" required class="textarea textarea-bordered w-full h-24">${product.description}</textarea>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="form-control">
              <label class="label">
                <span class="label-text font-semibold">Precio</span>
                <span class="label-text-alt text-gray-500">Dejar vacío para "Call for Pricing"</span>
              </label>
              <input type="number" name="price" step="0.01" class="input input-bordered w-full" value="${product.price || ''}" />
            </div>

            <div class="form-control">
              <label class="label">
                <span class="label-text font-semibold">Unidad de Precio</span>
              </label>
              <input type="text" name="priceUnit" class="input input-bordered w-full" value="${product.priceUnit || '/ ton'}" />
            </div>
          </div>

          <div class="form-control">
            <label class="label">
              <span class="label-text font-semibold">URL de Imagen *</span>
            </label>
            <input type="url" name="imageUrl" required class="input input-bordered w-full" value="${product.imageUrl}" />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="form-control">
              <label class="label">
                <span class="label-text font-semibold">Badge (Opcional)</span>
              </label>
              <input type="text" name="badge" class="input input-bordered w-full" value="${product.badge || ''}" />
            </div>

            <div class="form-control">
              <label class="label">
                <span class="label-text font-semibold">Orden *</span>
              </label>
              <input type="number" name="order" required class="input input-bordered w-full" value="${product.order}" min="0" />
            </div>
          </div>

          <div class="form-control">
            <label class="label cursor-pointer justify-start gap-3">
              <input type="checkbox" name="isActive" ${product.isActive ? 'checked' : ''} class="checkbox checkbox-primary" />
              <span class="label-text font-semibold">Producto activo (visible en la página)</span>
            </label>
          </div>

          <div class="flex gap-3 pt-4">
            <button type="submit" class="btn btn-primary">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Guardar Cambios
            </button>
            <a href="/admin/products" class="btn btn-ghost">Cancelar</a>
          </div>
        </form>
      `;

      const form = document.getElementById('product-form') as HTMLFormElement;
      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formData = new FormData(form);
        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="loading loading-spinner"></span> Guardando...';
        
        try {
          const price = formData.get('price') as string;
          
          await updateDoc(doc(db, 'products', productId), {
            name: formData.get('name'),
            description: formData.get('description'),
            price: price ? parseFloat(price) : null,
            priceUnit: formData.get('priceUnit') || '/ ton',
            imageUrl: formData.get('imageUrl'),
            badge: formData.get('badge') || null,
            order: parseInt(formData.get('order') as string),
            isActive: formData.get('isActive') === 'on',
            updatedAt: Timestamp.now()
          });
          
          alert('Producto actualizado exitosamente');
          window.location.href = '/admin/products';
        } catch (error) {
          console.error('Error updating product:', error);
          alert('Error al actualizar el producto');
          submitBtn.disabled = false;
          submitBtn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Guardar Cambios';
        }
      });

    } catch (error) {
      console.error('Error loading product:', error);
      container.innerHTML = `
        <div class="text-center py-8">
          <p class="text-error font-semibold">Error al cargar el producto</p>
          <p class="text-sm text-gray-600 mt-2">${error instanceof Error ? error.message : 'Error desconocido'}</p>
          <a href="/admin/products" class="btn btn-primary mt-4">Volver a productos</a>
        </div>
      `;
    }
  }

  loadProduct();
</script>
