---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Reviews">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Customer Reviews</h1>
      <p class="text-gray-600 mt-1">Moderate and manage reviews displayed on the main site</p>
    </div>
    <a href="/admin/reviews/new" class="btn btn-primary">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      New Review
    </a>
  </div>

  <div class="tabs tabs-boxed mb-6">
    <a class="tab tab-active" data-filter="all">All</a>
    <a class="tab" data-filter="approved">Approved</a>
    <a class="tab" data-filter="pending">Pending</a>
  </div>

  <div id="reviews-container" class="bg-white rounded-lg shadow">
    <div class="p-8 text-center text-gray-500">
      Loading reviews...
    </div>
  </div>
</AdminLayout>

<script>
  import { collection, query, orderBy, getDocs, deleteDoc, doc, updateDoc, where } from 'firebase/firestore';
  import { db } from '../../../firebase/client';
  import type { Review } from '../../../firebase/types';

  let currentFilter = 'all';

  async function loadReviews() {
    const container = document.getElementById('reviews-container');
    if (!container) return;

    try {
      let q;
      if (currentFilter === 'approved') {
        q = query(collection(db, 'reviews'), where('isApproved', '==', true), orderBy('date', 'desc'));
      } else if (currentFilter === 'pending') {
        q = query(collection(db, 'reviews'), where('isApproved', '==', false), orderBy('date', 'desc'));
      } else {
        q = query(collection(db, 'reviews'), orderBy('date', 'desc'));
      }
      
      const querySnapshot = await getDocs(q);
      const reviews: Review[] = [];
      
      querySnapshot.forEach((doc) => {
        reviews.push({ id: doc.id, ...doc.data() } as Review);
      });

      if (reviews.length === 0) {
        container.innerHTML = `
          <div class="p-12 text-center">
            <div class="text-6xl mb-4">⭐</div>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">No reviews yet</h3>
            <p class="text-gray-600 mb-6">Start by adding the first review</p>
            <a href="/admin/reviews/new" class="btn btn-primary inline-flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
              </svg>
              Create Review
            </a>
          </div>
        `;
        return;
      }

      container.innerHTML = `
        <div class="divide-y">
          ${reviews.map(review => {
            const date = review.date?.toDate ? review.date.toDate() : new Date();
            return `
              <div class="p-6 hover:bg-gray-50 transition">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1">
                    <div class="flex items-center gap-3 mb-2">
                      <div class="avatar placeholder">
                        <div class="bg-primary text-primary-content rounded-full w-10">
                          <span class="text-sm font-semibold">${review.authorInitials}</span>
                        </div>
                      </div>
                      <div>
                        <div class="font-semibold text-gray-900">${review.author}</div>
                        <div class="text-sm text-gray-500">${review.source || 'Customer Review'}</div>
                      </div>
                      <div class="flex gap-1">
                        ${Array.from({length: review.rating}).map(() => 
                          '<svg class="w-4 h-4 fill-warning" viewBox="0 0 24 24"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>'
                        ).join('')}
                      </div>
                    </div>
                    <p class="text-gray-700 mb-3">"${review.content}"</p>
                    <div class="flex items-center gap-4 text-sm text-gray-500">
                      <span>${date.toLocaleDateString('en-US')}</span>
                      <button 
                        onclick="toggleApproval('${review.id}', ${review.isApproved})"
                        class="badge ${review.isApproved ? 'badge-success' : 'badge-warning'} cursor-pointer"
                      >
                        ${review.isApproved ? '✓ Approved' : '⏳ Pending'}
                      </button>
                    </div>
                  </div>
                  <div class="flex gap-2">
                    <a href="/admin/reviews/edit/${review.id}" class="btn btn-sm btn-ghost">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                      </svg>
                    </a>
                    <button onclick="deleteReview('${review.id}', '${review.author}')" class="btn btn-sm btn-ghost text-error">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                      </svg>
                    </button>
                  </div>
                </div>
              </div>
            `;
          }).join('')}
        </div>
      `;
    } catch (error) {
      console.error('Error loading reviews:', error);
      container.innerHTML = `
        <div class="p-8 text-center text-error">
          <p class="font-semibold mb-2">Error loading reviews</p>
          <p class="text-sm">${error instanceof Error ? error.message : 'Unknown error'}</p>
        </div>
      `;
    }
  }

  (window as any).toggleApproval = async (id: string, currentStatus: boolean) => {
    try {
      await updateDoc(doc(db, 'reviews', id), {
        isApproved: !currentStatus
      });
      await loadReviews();
    } catch (error) {
      console.error('Error updating approval:', error);
      alert('Error updating review status');
    }
  };

  (window as any).deleteReview = async (id: string, author: string) => {
    if (!confirm(`Are you sure you want to delete the review by "${author}"?`)) return;
    
    try {
      await deleteDoc(doc(db, 'reviews', id));
      await loadReviews();
    } catch (error) {
      console.error('Error deleting review:', error);
      alert('Error deleting review');
    }
  };

  // Tab filtering
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', (e) => {
      e.preventDefault();
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('tab-active'));
      (e.target as HTMLElement).classList.add('tab-active');
      currentFilter = (e.target as HTMLElement).dataset.filter || 'all';
      loadReviews();
    });
  });

  loadReviews();
</script>
