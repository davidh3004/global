---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import CheckoutWrapper from '../components/cart/CheckoutWrapper';

const locale = Astro.currentLocale || 'en';
const isEnglish = locale === 'en';
---

<BaseLayout 
  title={isEnglish ? "Checkout - Global Recycling" : "Finalizar Compra - Global Recycling"}
  description={isEnglish ? "Complete your purchase" : "Completa tu compra"}
  lang={locale}
>
  <Header lang={locale} />
  
  <div style="min-height: 100vh; background: var(--gray-50); padding: 120px 0 60px;">
    <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
