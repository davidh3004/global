---
import { t } from '../../utils/i18n';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const isEnglish = lang === 'en';
const basePath = isEnglish ? '/en' : '';
---

<footer>
  <div class="footer-grid">
    <div>
      <a href={basePath || '/'} class="footer-logo">
        <span style="font-size: 18px; font-weight: 700; color: var(--green);">Global Recycling of Tampa Bay</span>
      </a>
      <p class="footer-desc">{t('footer.description', lang)}</p>
      <div class="footer-social">
        <div class="soc-btn"><svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></div>
        <div class="soc-btn"><svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg></div>
        <div class="soc-btn"><svg viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/></svg></div>
      </div>
    </div>
    <div>
      <div class="footer-col-title">{t('footer.navigation', lang)}</div>
      <ul class="footer-links">
        <li><a href="/#hero">{t('nav.home', lang)}</a></li>
        <li><a href="/#about">{t('nav.about', lang)}</a></li>
        <li><a href="/#products">{t('nav.materials', lang)}</a></li>
        <li><a href="/#learning">{t('nav.learning', lang)}</a></li>
        <li><a href="/#contact">{t('nav.contact', lang)}</a></li>
      </ul>
    </div>
    <div>
      <div class="footer-col-title">{t('footer.materials', lang)}</div>
      <ul class="footer-links">
        <li><a href={`${basePath}/${isEnglish ? 'materials/crushed-concrete' : 'materiales/concreto-triturado'}`}>{t('quote.materials.concrete', lang)}</a></li>
        <li><a href={`${basePath}/${isEnglish ? 'materials/asphalt' : 'materiales/asfalto'}`}>{t('quote.materials.asphalt', lang)}</a></li>
        <li><a href={`${basePath}/${isEnglish ? 'materials/road-base' : 'materiales/base-carretera'}`}>{t('quote.materials.roadBase', lang)}</a></li>
        <li><a href={`${basePath}/${isEnglish ? 'materials/paver-base' : 'materiales/base-pavimento'}`}>{t('quote.materials.paverBase', lang)}</a></li>
        <li><a href={`${basePath}/${isEnglish ? 'materials/fill' : 'materiales/relleno'}`}>{t('ticker.fill', lang)}</a></li>
      </ul>
    </div>
    <div>
      <div class="footer-col-title">{t('footer.contact', lang)}</div>
      <div class="footer-contact-item"><svg viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg><span>5011 N. Clark St.<br/>Tampa, FL 33614</span></div>
      <div class="footer-contact-item"><svg viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg><span>(813) 373-6467</span></div>
      <div class="footer-contact-item"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg><span set:html={t('contact.hoursValue', lang)}></span></div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="footer-copy">{t('footer.copyright', lang)}</div>
    <div class="footer-built">{t('footer.builtBy', lang)}</div>
  </div>
</footer>
