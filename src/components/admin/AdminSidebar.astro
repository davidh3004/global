---
/**
 * Admin Sidebar - Navigation for admin panel
 * Active state is determined by matching the current URL path
 */
const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/admin') return currentPath === '/admin' || currentPath === '/admin/';
  return currentPath.startsWith(href);
}

function activeClass(href: string): string {
  return isActive(href) ? 'active' : '';
}
