---
// Stats section con estilos exactos del diseño original
---

<div class="px-6 py-10 border-b border-gray-200 bg-gray-50">
  <div class="max-w-[1280px] mx-auto grid grid-cols-2 md:grid-cols-4 bg-white border border-gray-200 rounded-[10px] overflow-hidden">
    <div class="px-5 py-6 text-center border-r border-gray-200 fade last:border-r-0">
      <div class="font-display text-4xl font-extrabold text-green leading-none mb-1.5">42+</div>
      <div class="text-[11px] text-gray-400 uppercase tracking-[1px]">Years Operating</div>
    </div>
    <div class="px-5 py-6 text-center border-r border-gray-200 fade fade-d1 last:border-r-0">
      <div class="font-display text-4xl font-extrabold text-green leading-none mb-1.5">14,400</div>
      <div class="text-[11px] text-gray-400 uppercase tracking-[1px]">Cubic Yards Excavated</div>
    </div>
    <div class="px-5 py-6 text-center border-r border-gray-200 fade fade-d2 last:border-r-0">
      <div class="font-display text-4xl font-extrabold text-green leading-none mb-1.5">100%</div>
      <div class="text-[11px] text-gray-400 uppercase tracking-[1px]">Recycled — Zero Landfill</div>
    </div>
    <div class="px-5 py-6 text-center border-r border-gray-200 fade fade-d3 last:border-r-0">
      <div class="font-display text-4xl font-extrabold text-green leading-none mb-1.5">4.3★</div>
      <div class="text-[11px] text-gray-400 uppercase tracking-[1px]">Google Rating</div>
    </div>
  </div>
</div>
