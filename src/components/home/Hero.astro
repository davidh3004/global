---
// Hero section con estilos exactos del diseño original
interface Props {
  heroTitle?: string;
  heroSubtitle?: string;
  backgroundImage?: string;
}

const { 
  heroTitle = "The World Is Yours. Recycle It.",
  heroSubtitle = "Recycled concrete, asphalt, and aggregate materials for roads, driveways, and construction projects. Serving Tampa Bay for 42+ years.",
  backgroundImage = "https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1600&q=80"
} = Astro.props;
---

<section class="min-h-[580px] bg-gray-900 relative overflow-hidden flex items-center pt-[68px]">
  <!-- Background image con opacidad exacta -->
  <div 
    class="absolute inset-0 bg-center bg-cover bg-no-repeat opacity-[0.22]"
    style={`background-image: url('${backgroundImage}')`}
  ></div>
  
  <div class="relative z-[2] max-w-[1280px] mx-auto px-6 py-16 grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 items-center w-full">
    <div>
      <!-- Label con animación blink -->
      <div class="inline-flex items-center gap-2 bg-green/15 border border-green/30 rounded-full px-3.5 py-1 text-[11px] font-semibold text-[#6FD98B] tracking-[1.5px] uppercase mb-5">
        <div class="hero-label-dot"></div>
        Tampa Bay's Recycling Leader Since 1990
      </div>
      
      <!-- Título principal -->
      <h1 class="font-display text-[clamp(44px,5.5vw,68px)] font-extrabold leading-[1.05] text-white tracking-[-1.5px] mb-4">
        The World<br/>Is <span class="text-[#6FD98B]">Yours.</span><br/>Recycle It.
      </h1>
      
      <p class="text-base leading-relaxed text-white/70 max-w-[520px] mb-8">
        {heroSubtitle}
      </p>
      
      <!-- Botones -->
      <div class="flex flex-wrap gap-3 mb-10">
        <a href="/materials" class="px-6 py-3 rounded-lg bg-green text-white text-sm font-bold no-underline transition-all duration-200 inline-flex items-center gap-2 hover:bg-green-dark hover:-translate-y-0.5 hover:shadow-[0_6px_24px_rgba(45,140,78,0.4)]">
          Shop Materials →
        </a>
        <a href="/quote" class="px-6 py-3 rounded-lg border-[1.5px] border-white/25 text-white bg-transparent text-sm font-semibold no-underline transition-all duration-200 inline-flex items-center gap-2 hover:border-white/50 hover:bg-white/8">
          Request a Quote
        </a>
      </div>
      
      <!-- Stats -->
      <div class="flex gap-8">
        <div>
          <div class="font-display text-[28px] font-extrabold text-white leading-none">42+</div>
          <div class="text-[11px] text-white/50 mt-1 tracking-[0.5px] uppercase">Years Experience</div>
        </div>
        <div>
          <div class="font-display text-[28px] font-extrabold text-white leading-none">4.3★</div>
          <div class="text-[11px] text-white/50 mt-1 tracking-[0.5px] uppercase">Google Rating</div>
        </div>
        <div>
          <div class="font-display text-[28px] font-extrabold text-white leading-none">MON–SAT</div>
          <div class="text-[11px] text-white/50 mt-1 tracking-[0.5px] uppercase">7am – 5pm</div>
        </div>
      </div>
    </div>
    
    <!-- Quote Card -->
    <div class="bg-white rounded-xl p-7 shadow-[0_16px_48px_rgba(0,0,0,0.2)] hidden lg:block">
      <div class="mb-1 text-lg font-extrabold text-gray-900 font-display">Quick Quote</div>
      <div class="mb-5 text-xs text-gray-400">We respond same day</div>
      
      <form id="heroQuoteForm">
        <div class="mb-3">
          <label class="block text-[11px] font-semibold text-gray-600 uppercase tracking-[0.5px] mb-1">Your Name</label>
          <input type="text" name="name" required placeholder="John Smith" class="w-full px-3 py-2 rounded-md border-[1.5px] border-gray-200 text-[13px] text-gray-800 bg-white transition-colors duration-150 outline-none focus:border-green" />
        </div>
        
        <div class="grid grid-cols-2 gap-2.5 mb-3">
          <div>
            <label class="block text-[11px] font-semibold text-gray-600 uppercase tracking-[0.5px] mb-1">Material</label>
            <select name="material" class="w-full px-3 py-2 rounded-md border-[1.5px] border-gray-200 text-[13px] text-gray-800 bg-white transition-colors duration-150 outline-none focus:border-green">
              <option>Crushed Concrete</option>
              <option>Recycled Asphalt</option>
              <option>Road Base</option>
              <option>Paver Base</option>
            </select>
          </div>
          <div>
            <label class="block text-[11px] font-semibold text-gray-600 uppercase tracking-[0.5px] mb-1">Quantity</label>
            <input type="text" name="quantity" required placeholder="10 tons" class="w-full px-3 py-2 rounded-md border-[1.5px] border-gray-200 text-[13px] text-gray-800 bg-white transition-colors duration-150 outline-none focus:border-green" />
          </div>
        </div>
        
        <div class="mb-3">
          <label class="block text-[11px] font-semibold text-gray-600 uppercase tracking-[0.5px] mb-1">Phone or Email</label>
          <input type="text" name="contact" required placeholder="(813) 000-0000" class="w-full px-3 py-2 rounded-md border-[1.5px] border-gray-200 text-[13px] text-gray-800 bg-white transition-colors duration-150 outline-none focus:border-green" />
        </div>
        
        <div id="heroQuoteMsg" style="display:none; padding: 8px; border-radius: 6px; font-size: 13px; margin-bottom: 8px;"></div>
        
        <button type="submit" id="heroQuoteBtn" class="w-full py-2.5 rounded-lg bg-green text-white text-sm font-bold border-none cursor-pointer transition-all duration-150 mt-1 hover:bg-green-dark">
          Send Request →
        </button>
        
        <div class="flex items-center gap-2 my-3.5 text-[11px] text-gray-300">
          <div class="flex-1 h-px bg-gray-200"></div>
          or call directly
          <div class="flex-1 h-px bg-gray-200"></div>
        </div>
        
        <a href="tel:8133736467" class="flex items-center justify-center gap-2 text-sm font-bold no-underline text-green font-display">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
          </svg>
          (813) 373-6467
        </a>
      </form>
    </div>
  </div>
</section>

<script>
  import { createLead } from '../../services/lead.service';

  const form = document.getElementById('heroQuoteForm') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('heroQuoteBtn') as HTMLButtonElement;
      const msg = document.getElementById('heroQuoteMsg') as HTMLDivElement;
      const fd = new FormData(form);

      btn.disabled = true;
      btn.textContent = 'Sending...';
      msg.style.display = 'none';

      try {
        await createLead({
          name: fd.get('name') as string,
          material: fd.get('material') as string,
          quantity: fd.get('quantity') as string,
          contact: fd.get('contact') as string,
        });
        msg.style.display = 'block';
        msg.style.background = '#D1FAE5';
        msg.style.color = '#065F46';
        msg.textContent = 'Request sent! We will contact you shortly.';
        form.reset();
      } catch (err: any) {
        msg.style.display = 'block';
        msg.style.background = '#FEE2E2';
        msg.style.color = '#991B1B';
        msg.textContent = 'Error sending request. Please try again.';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Send Request →';
      }
    });
  }
</script>
