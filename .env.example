# ============================================
# FIREBASE CONFIGURATION
# ============================================
# How to get credentials:
# 1. Go to Firebase Console: https://console.firebase.google.com
# 2. Select your project (or create a new one)
# 3. Go to Project Settings > General
# 4. Under "Your apps", select the web app or create a new one
# 5. Copy the configuration credentials

PUBLIC_FIREBASE_API_KEY=your_api_key_here
PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your_project_id
PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
PUBLIC_FIREBASE_APP_ID=your_app_id

# ============================================
# FIREBASE ADMIN SDK (Server-side)
# ============================================
# Required for managing users, custom claims, and admin operations.
# How to obtain:
# 1. Go to Firebase Console > Project Settings > Service Accounts
# 2. Click "Generate new private key"
# 3. Download the JSON file
# 4. Stringify the JSON content (single line, escaped) and paste below
# IMPORTANT: This is the FULL JSON content of the service account key, stringified.
# Example: {"type":"service_account","project_id":"...","private_key":"...","client_email":"...",...}
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project-id","private_key_id":"your_key_id","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com","client_id":"your_client_id","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project-id.iam.gserviceaccount.com","universe_domain":"googleapis.com"}

# ============================================
# QUICKBOOKS PAYMENTS CONFIGURATION
# ============================================
# How to get credentials:
# 1. Go to QuickBooks Developer Portal: https://developer.intuit.com
# 2. Create a developer account
# 3. Create a new app in "My Apps"
# 4. Select "QuickBooks Online and Payments"
# 5. Copy Client ID and Client Secret
# 6. Configure Redirect URIs and Webhook URLs
# Full documentation: docs/quickbooks-setup.md

QUICKBOOKS_CLIENT_ID=your_quickbooks_client_id
QUICKBOOKS_CLIENT_SECRET=your_quickbooks_client_secret
QUICKBOOKS_ENVIRONMENT=sandbox
QUICKBOOKS_REDIRECT_URI=http://localhost:4321/api/auth/quickbooks/callback
QUICKBOOKS_WEBHOOK_SECRET=your_webhook_secret
QUICKBOOKS_COMPANY_ID=your_realm_id

# Notes:
# - QUICKBOOKS_ENVIRONMENT: use "sandbox" for development, "production" for production
# - QUICKBOOKS_COMPANY_ID (Realm ID): obtained after completing the OAuth flow
# - QUICKBOOKS_WEBHOOK_SECRET: generate a secure random string for webhook verification

# ============================================
# SITE CONFIGURATION
# ============================================
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_COMPANY_NAME=Global Recycling of Tampa Bay
PUBLIC_COMPANY_PHONE=(813) 373-6467
PUBLIC_COMPANY_EMAIL=info@globalrecyclingtb.com

# ============================================
# EMAIL CONFIGURATION (Optional - for notifications)
# ============================================
# For sending order confirmation emails, etc.
# You can use services like SendGrid, Mailgun, or SMTP

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=noreply@globalrecyclingtb.com

# ============================================
# IMPORTANT NOTES
# ============================================
# 1. NEVER commit the .env file to Git (already in .gitignore)
# 2. For production, set these variables in Vercel:
#    - Go to your project in Vercel
#    - Settings > Environment Variables
#    - Add each variable with its value
# 3. Restart the dev server after changing environment variables
# 4. Variables starting with PUBLIC_ are accessible on the client
# 5. Variables without PUBLIC_ are only available on the server

# Google reCAPTCHA v3
PUBLIC_RECAPTCHA_SITE_KEY=your_site_key
RECAPTCHA_SECRET_KEY=your_secret_key
 
# Resend Email
RESEND_API_KEY=your_api_key
CONTACT_EMAIL_TO=info@globalrecyclingtampabay.com
CONTACT_EMAIL_FROM=noreply@globalrecyclingtampabay.com